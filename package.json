{
  "name": "tree-ssot-explain",
  "private": true,
  "type": "module",
  "description": "多树形结构 · 节点交织模型(3D 可视化)",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "check": "node scripts/build-embedded.mjs --check && node scripts/check-narrative.mjs",
    "build": "node scripts/build-embedded.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:en": "node scripts/smoke-test.mjs --lang=en",
    "smoke:embedded": "node scripts/smoke-test.mjs --embedded",
    "verify": "pnpm run check && pnpm run smoke && pnpm run smoke:en && pnpm run build && pnpm run smoke:embedded",
    "serve": "python3 -m http.server 4173"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "puppeteer-core": "^25.3.0"
  }
}
